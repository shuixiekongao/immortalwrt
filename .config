CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7620=y
CONFIG_TARGET_ramips_mt7620_DEVICE_k2p=y
CONFIG_HAS_SUBTARGETS=y
CONFIG_HAS_DEVICES=y
CONFIG_TARGET_BOARD="ramips"
CONFIG_TARGET_SUBTARGET="mt7620"
CONFIG_TARGET_PROFILE="k2p"
CONFIG_TARGET_ARCH="mips"
CONFIG_TARGET_ARCH_PACKAGES="mips_24kc"
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe -march=74kc -mtune=74kc -mno-check-zero-division"
CONFIG_CPU_TYPE="74kc"

# 固件压缩
CONFIG_KERNEL_GZIP=y
CONFIG_KERNEL_XZ=y
CONFIG_SQUASHFS_TOOLS_MKSQUASHFS_LZ4=y
CONFIG_KERNEL_SQUASHFS_LZ4=y

# 内存和存储优化
CONFIG_INIT_MOUNT_RW=y
CONFIG_KERNEL_BUILD_USER="ImmortalWrt"
CONFIG_KERNEL_BUILD_DOMAIN="OpenWrt"

# ZRAM 压缩内存
CONFIG_PACKAGE_zram-swap=y
CONFIG_ZRAM_DEF_COMP_ALGORITHM="lz4"
CONFIG_ZRAM_DEF_DEV_SIZE=52428800

# Swap 配置
CONFIG_PACKAGE_swap-utils=y

# USB 支持
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-uas=y

# 文件系统支持
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_e2fsprogs=y

# Samba 文件共享
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_SAMBA4_SERVER_QUOTAS=y
CONFIG_SAMBA4_SERVER_AD_DC=n

# LuCI Web界面 (精简版)
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y

# 网络优化
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat-extra=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_kmod-bnx2=n
CONFIG_PACKAGE_kmod-bnx2x=n

# IPv6 支持
CONFIG_PACKAGE_kmod-ipv6=y
CONFIG_PACKAGE_ip6tables=y

# DNS/DHCP
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_DNSMASQ_DHCP_BOOT=y

# WireGuard VPN (可选)
CONFIG_PACKAGE_wireguard-tools=n
CONFIG_PACKAGE_kmod-wireguard=n

# OpenVPN (可选,需要空间)
CONFIG_PACKAGE_openvpn-openssl=n

# ShadowSocks 科学上网
CONFIG_PACKAGE_shadowsocks-libev=n
CONFIG_PACKAGE_luci-app-shadowsocks-libev=n

# 系统工具
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_vim-full=n
CONFIG_PACKAGE_less=y

# 文本处理
CONFIG_PACKAGE_grep=y
CONFIG_PACKAGE_sed=y
CONFIG_PACKAGE_gawk=y

# 诊断工具
CONFIG_PACKAGE_ping=y
CONFIG_PACKAGE_traceroute=y
CONFIG_PACKAGE_mtr=n
CONFIG_PACKAGE_nmap=n

# 监控
CONFIG_PACKAGE_collectd=n
CONFIG_PACKAGE_collectd-mod-cpu=n
CONFIG_PACKAGE_collectd-mod-interface=n
CONFIG_PACKAGE_collectd-mod-load=n
CONFIG_PACKAGE_collectd-mod-memory=n
CONFIG_PACKAGE_collectd-mod-rrdtool=n

# 关闭不必要的功能
CONFIG_PACKAGE_6to4=n
CONFIG_PACKAGE_ipv6helper=n
CONFIG_PACKAGE_bnx2-firmware=n
CONFIG_PACKAGE_bnx2x-firmware=n
CONFIG_PACKAGE_brcmfmac4329-firmware=n
CONFIG_PACKAGE_brcmfmac43xx-firmware=n
CONFIG_PACKAGE_kmod-bnx2=n
CONFIG_PACKAGE_kmod-bnx2x=n
CONFIG_PACKAGE_kmod-bnx2-bnx2x=n

# 内核优化
CONFIG_KERNEL_KALLSYMS=n
CONFIG_KERNEL_DEBUG_INFO=n
CONFIG_KERNEL_DEBUG_KERNEL=n
CONFIG_KERNEL_GDB=n

# 缓存配置
CONFIG_PACKAGE_ccache=n
CONFIG_CCACHE_DIR="/tmp/.ccache"

# 版本标记
CONFIG_VERSION_DIST="ImmortalWrt-K2P-32M-512M-USB"
CONFIG_VERSION_NUMBER="v25.12.0"
CONFIG_VERSION_REPO="https://github.com/shuixiekongao/immortalwrt"
